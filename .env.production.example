# Production settings — set these as environment variables on your server
# DO NOT commit this file. Use your hosting platform's env variable manager.

DATABASE_URL=postgresql+psycopg2://youruser:yourpass@your-host:5432/hospital_ai
SECRET_KEY=<generate-with-openssl-rand-hex-32>
GEMINI_API_KEY=your-key
ELEVENLABS_API_KEY=your-key
ELEVENLABS_WEBHOOK_URL=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_APP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_USE_TLS=true
